# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=4000

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (without database name)
# Example: mongodb+srv://user:password@cluster.mongodb.net
MONGODB_URL=

# Name of the MongoDB database
DATABASE_NAME=shop

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key for signing JWT access tokens (min 32 chars recommended)
JWT_ACCESS_SECRET=

# Secret key for signing JWT refresh tokens (min 32 chars recommended)
JWT_REFRESH_SECRET=

# Access token expiry (e.g. "15m", "1h")
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry (e.g. "7d", "30d")
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces after commas)
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Client application URL (used for Stripe redirect URLs, emails, etc.)
CLIENT_URL=http://localhost:5173

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_)
# Get this from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Cloudinary cloud name (from Dashboard)
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key
CLOUDINARY_API_KEY=

# Cloudinary API secret
CLOUDINARY_API_SECRET=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram chat ID where order notifications are sent
TELEGRAM_CHAT_ID=

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Sentry DSN for error tracking (get from sentry.io → Project → Settings → DSN)
# Leave empty to disable Sentry
SENTRY_DSN= 
# UptimeRobot / Better Stack setup (external service, no code needed):
# 1. Register at uptimerobot.com or betterstack.com (free tier)
# 2. Add HTTP monitor → URL: https://your-api.com/api/v1/health
# 3. Interval: every 5 minutes
# 4. Alert: Telegram or email on DOWN event
