# ─── API ──────────────────────────────────────────────────────────────────────
# Full base URL of the backend API including version prefix
# Development:  http://localhost:4000/api/v1
# Production:   https://your-api-domain.com/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Sentry DSN for frontend error tracking (get from sentry.io → Project → Settings → DSN)
# Leave empty to disable Sentry
VITE_SENTRY_DSN= 
